            "cwd": "${workspaceFolder}",
            "justMyCode": true
        },
        {
            "name": "Run demo Inference with Tool",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/demo/inference_with_tool_and_mcp.py",
            "console": "integratedTerminal",
