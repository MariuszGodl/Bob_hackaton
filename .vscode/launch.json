            "program": "${workspaceFolder}/agents/usage/mcp_servers/ibm_watsonx_mcp.py",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}",
            "justMyCode": true
